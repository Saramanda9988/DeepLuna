# DeepLuna 环境变量配置示例
# 复制此文件为 .env 并填入您的实际配置

# ==================== 数据库配置 ====================
APPLICATION_PGSQL_IP=postgres
APPLICATION_PGSQL_PORT=5432
APPLICATION_PGSQL_DB=postgres
APPLICATION_PGSQL_USERNAME=postgres
APPLICATION_PGSQL_PASSWORD=postgres

# ==================== AI API Keys ====================
# DeepSeek API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ZhipuAI API Key (智谱AI)
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# OpenAI API Key (可选)
# OPENAI_API_KEY=your-openai-api-key-here

# ==================== Web 搜索 API ====================
# Tavily Web Search API Key
WEBSEARCH_TAVILY_API_KEY=your-tavily-api-key-here

# ==================== 应用配置 ====================
SPRING_PROFILES_ACTIVE=prod
